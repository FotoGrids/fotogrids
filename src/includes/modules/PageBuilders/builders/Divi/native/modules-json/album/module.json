{
  "name": "fotogrids/fotogrids-album",
  "d4Shortcode": "",
  "title": "FotoGrids Album",
  "titles": "FotoGrids Albums",
  "moduleIcon": "fotogrids/module-album",
  "moduleClassName": "fotogrids_divi_album",
  "moduleOrderClassName": "fotogrids_divi_album",
  "category": "module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "settings": {
        "meta": { "adminLabel": {} },
        "advanced": { "link": {}, "htmlAttributes": {} },
        "decoration": {
          "attributes": {}, "background": {}, "sizing": {}, "spacing": {},
          "border": {}, "boxShadow": {}, "filters": {}, "transform": {},
          "animation": {}, "overflow": {}, "disabledOn": {}, "transition": {},
          "position": {}, "zIndex": {}, "scroll": {}, "sticky": {}
        }
      }
    },
    "album": {
      "type": "object",
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "mainContent",
            "attrName": "album.innerContent",
            "subName": "albumId",
            "priority": 10,
            "render": true,
            "label": "Album",
            "description": "Choose the FotoGrids album to display.",
            "category": "configuration",
            "features": { "hover": false, "sticky": false, "responsive": false, "dynamicContent": false },
            "component": { "type": "field", "name": "divi/select", "props": { "options": {} } }
          }
        }
      }
    },
    "previewClickBehavior": {
      "type": "object",
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "mainContent",
            "attrName": "previewClickBehavior.innerContent",
            "subName": "enabled",
            "priority": 20,
            "render": true,
            "label": "Make items clickable",
            "description": "When off, item clicks select the module in the builder instead of opening the album action. Published pages are not affected.",
            "category": "configuration",
            "features": { "hover": false, "sticky": false, "responsive": false, "dynamicContent": false },
            "component": { "type": "field", "name": "divi/toggle" }
          }
        }
      }
    },
    "previewPagination": {
      "type": "object",
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "mainContent",
            "attrName": "previewPagination.innerContent",
            "subName": "enabled",
            "priority": 30,
            "render": true,
            "label": "Enable pagination controls",
            "description": "When off, pagination controls stay visible but inactive in the builder. Published pages are not affected.",
            "category": "configuration",
            "features": { "hover": false, "sticky": false, "responsive": false, "dynamicContent": false },
            "component": { "type": "field", "name": "divi/toggle" }
          }
        }
      }
    }
  },
  "customCssFields": {},
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "mainContent": {
        "panel": "content",
        "priority": 10,
        "groupName": "mainContent",
        "component": {
          "name": "divi/composite",
          "props": { "groupLabel": "Album" }
        }
      }
    }
  }
}
