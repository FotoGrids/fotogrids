{
    "id": "pagination",
    "label": "Pagination",
    "icon": "layers",
    "condition": {
        "dependsOn": "layout",
        "values": [
            "grid",
            "masonry",
            "justified",
            "instant-photos"
        ]
    },
    "settings": [
        {
            "key": "pagination_type",
            "type": "button_group",
            "label": "Display Mode",
            "options": [
                {
                    "label": "Break into Pages",
                    "value": "paginated",
                    "tier_required": "free"
                },
                {
                    "label": "Show All Items",
                    "value": "show_all",
                    "tier_required": "free"
                }
            ],
            "default": "paginated",
            "tier_required": "free",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "items_per_page",
            "type": "responsive_range",
            "label": "Items Per Page",
            "responsive": {
                "desktop": {
                    "min": 1,
                    "max": 100,
                    "default": 24
                },
                "tablet": {
                    "min": 1,
                    "max": 50,
                    "default": 18
                },
                "mobile": {
                    "min": 1,
                    "max": 30,
                    "default": 12
                }
            },
            "condition": {
                "dependsOn": "pagination_type",
                "values": [
                    "paginated"
                ]
            },
            "tier_required": "free",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "preload_next_page",
            "type": "toggle",
            "label": "Preload Next Page",
            "description": "Preload next page content in the background for even faster navigation.",
            "default": false,
            "condition": {
                "dependsOn": "pagination_type",
                "values": [
                    "paginated"
                ]
            },
            "tier_required": "pro_starter",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "pagination_method",
            "type": "button_group",
            "label": "Pagination Method",
            "options": [
                {
                    "label": "Endless Scroll",
                    "value": "endless_scroll",
                    "icon": "arrow_square_down",
                    "tier_required": "free"
                },
                {
                    "label": "Load More Button",
                    "value": "load_more",
                    "icon": "plus_square",
                    "tier_required": "free"
                },
                {
                    "label": "Page Buttons",
                    "value": "pages",
                    "icon": "code_square",
                    "tier_required": "free"
                }
            ],
            "default": "load_more",
            "condition": {
                "dependsOn": "pagination_type",
                "values": [
                    "paginated"
                ]
            },
            "tier_required": "free",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "pagination_distance_from_items",
            "type": "responsive_range",
            "label": "Distance From Items",
            "description": "Space between the gallery items and the pagination controls.",
            "units": [ "px", "em", "rem" ],
            "responsive": {
                "desktop": { "min": 0, "max": 100, "default": 16 },
                "tablet":  { "min": 0, "max": 100, "default": 16 },
                "mobile":  { "min": 0, "max": 100, "default": 16 }
            },
            "condition": {
                "dependsOn": "pagination_type",
                "values": [
                    "paginated"
                ]
            },
            "tier_required": "free",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
