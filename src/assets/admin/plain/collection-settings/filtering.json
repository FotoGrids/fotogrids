{
    "id": "filtering",
    "label": "Filtering",
    "icon": "filter",
    "settings": [
        {
            "key": "filtering_enabled",
            "type": "toggle",
            "label": "Enable Filtering",
            "description": "Allow items to be filtered by different criteria",
            "default": false,
            "tier_required": "free",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "filter_by",
            "type": "token_select",
            "label": "Filter By",
            "description": "Which criteria visitors can filter items by",
            "options": [
                { "label": "Tags", "value": "tags", "tier_required": "free" },
                { "label": "People", "value": "people", "tier_required": "pro_starter" },
                { "label": "Location", "value": "location", "tier_required": "pro_starter" },
                { "label": "Date", "value": "date", "tier_required": "pro_starter" },
                { "label": "EXIF", "value": "exif", "tier_required": "pro_starter" }
            ],
            "default": ["tags"],
            "condition": {
                "dependsOn": "filtering_enabled",
                "values": [true, "1"]
            },
            "tier_required": "free",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "date_filter_type",
            "type": "button_group",
            "label": "Date Filter Type",
            "description": "Which date to use for filtering",
            "options": [
                {
                    "label": "Date Taken",
                    "value": "date_taken",
                    "icon": "camera",
                    "tier_required": "pro_starter"
                },
                {
                    "label": "Date Uploaded",
                    "value": "date_uploaded",
                    "icon": "upload",
                    "tier_required": "pro_starter"
                }
            ],
            "default": "date_taken",
            "condition": {
                "dependsOn": "filter_by",
                "values": ["date"],
                "condition_operator": "array_includes"
            },
            "tier_required": "pro_starter",
            "render_when_unlicensed": true,
            "setting_lives_in": "free",
            "visible_when_uninstalled": true
        },
        {
            "key": "filter_controls_subtabs",
            "type": "setting_subtabs",
            "label": "Filter Controls",
            "condition": {
                "dependsOn": "filtering_enabled",
                "values": [true, "1"]
            },
