{
	"partial": "typography",
	"layout": [
		{
			"wrap": "side_by_side",
			"fields": [
				"font_family",
				"font_weight",
				"font_style"
			]
		},
		"font_size",
		{
			"wrap": "side_by_side",
			"fields": [
				"line_height",
				"letter_spacing",
				"word_spacing"
			]
		}
	],
	"fields": {
		"font_family": {
			"type": "font_family",
			"label_template": "{{label}} Font Family",
			"label_template_empty": "Font Family",
			"default": "default",
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		},
		"font_weight": {
			"type": "font_weight",
			"label_template": "{{label}} Font Weight",
			"label_template_empty": "Font Weight",
			"default": "400",
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		},
		"font_style": {
			"type": "font_style",
			"label_template": "{{label}} Font Style",
			"label_template_empty": "Font Style",
			"default": "normal",
			"default_option_value": "normal",
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		},
		"font_size": {
			"type": "responsive_range",
			"label_template": "{{label}} Font Size",
			"label_template_empty": "Font Size",
			"units": [
				"px",
				"em",
				"rem"
			],
			"responsive": {
				"desktop": { "min": 8, "max": 72, "default": 18 },
				"tablet": { "min": 8, "max": 48, "default": 16 },
				"mobile": { "min": 8, "max": 36, "default": 14 }
			},
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		},
		"line_height": {
			"type": "responsive_range",
			"no_range": true,
			"allow_decimals": true,
			"label_template": "{{label}} Line Height",
			"label_template_empty": "Line Height",
			"units": [
				"em",
				"px",
				"rem"
			],
			"responsive": {
				"desktop": { "min": 0, "max": 5, "step": 0.1, "default": 1.2 },
				"tablet": { "min": 0, "max": 5, "step": 0.1, "default": 1.2 },
				"mobile": { "min": 0, "max": 5, "step": 0.1, "default": 1.2 }
			},
			"default": {
				"desktop": { "value": 1.2, "unit": "em" },
				"tablet": { "value": 1.2, "unit": "em" },
				"mobile": { "value": 1.2, "unit": "em" }
			},
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		},
		"letter_spacing": {
			"type": "responsive_range",
			"no_range": true,
			"allow_decimals": true,
			"label_template": "{{label}} Letter Spacing",
			"label_template_empty": "Letter Spacing",
			"units": [
				"em",
				"px",
				"rem"
			],
			"responsive": {
				"desktop": { "min": -5, "max": 20, "step": 0.1, "default": 0 },
				"tablet": { "min": -5, "max": 20, "step": 0.1, "default": 0 },
				"mobile": { "min": -5, "max": 20, "step": 0.1, "default": 0 }
			},
			"default": {
				"desktop": { "value": 0, "unit": "em" },
				"tablet": { "value": 0, "unit": "em" },
				"mobile": { "value": 0, "unit": "em" }
			},
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		},
		"word_spacing": {
			"type": "responsive_range",
			"no_range": true,
			"allow_decimals": true,
			"label_template": "{{label}} Word Spacing",
			"label_template_empty": "Word Spacing",
			"units": [
				"em",
				"px",
				"rem"
			],
			"responsive": {
				"desktop": { "min": -10, "max": 40, "step": 0.1, "default": 0 },
				"tablet": { "min": -10, "max": 40, "step": 0.1, "default": 0 },
				"mobile": { "min": -10, "max": 40, "step": 0.1, "default": 0 }
			},
			"default": {
				"desktop": { "value": 0, "unit": "em" },
				"tablet": { "value": 0, "unit": "em" },
				"mobile": { "value": 0, "unit": "em" }
			},
			"tier_required": "free",
			"render_when_unlicensed": true,
			"setting_lives_in": "free",
			"visible_when_uninstalled": true
		}
	}
}
