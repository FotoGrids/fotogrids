{
    "id": "media",
    "label": "Media",
    "icon": "image",
    "free": true,
    "postTypes": ["gallery"],
    "settings": [
        {
            "key": "thumbnail_size_group",
            "type": "setting_group",
            "label": "Thumbnail Size",
            "free": true,
            "settings": [
                {
                    "key": "thumbnail_size",
                    "type": "image_size",
                    "label": "",
                    "api_endpoint": "/wp-json/fotogrids/v1/admin/image-sizes",
                    "options_key": "sizes",
                    "default": "thumbnail",
                    "append_option": { "label": "Custom", "value": "custom" },
                    "fallback_options": [
                        { "label": "Thumbnail", "value": "thumbnail" },
                        { "label": "Medium", "value": "medium" },
                        { "label": "Large", "value": "large" },
                        { "label": "Full", "value": "full" }
                    ],
                    "free": true
                },
                {
                    "key": "thumbnail_custom_size",
                    "type": "setting_group",
                    "label": "Custom Thumbnail Size",
                    "condition": { "dependsOn": "thumbnail_size", "values": ["custom"] },
                    "free": true,
                    "settings": [
                        {
                            "key": "thumbnail_custom_size_width",
                            "type": "range",
                            "label": "Width",
                            "min": 50,
                            "max": 800,
                            "default": 150,
                            "unit": "px",
                            "free": true
                        },
                        {
                            "key": "thumbnail_custom_size_height",
                            "type": "range",
                            "label": "Height",
                            "min": 50,
                            "max": 800,
                            "default": 150,
                            "unit": "px",
                            "free": true
                        },
                        {
                            "key": "thumbnail_custom_size_crop",
                            "type": "toggle",
                            "label": "Hard Crop",
                            "default": false,
                            "description": "When enabled, images will be cropped to the exact width and height specified.<br>When disabled, images will be scaled to fit the dimensions while maintaining their aspect ratio.",
                            "free": true
                        },
                        {
                            "key": "thumbnail_custom_size_crop_alignment",
                            "type": "alignment_grid",
                            "label": "Crop Alignment",
                            "default": "center",
                            "options": [
                                { "value": "top-left", "icon": "dots_grid_top_left" },
                                { "value": "top-center", "icon": "dots_grid_top_center" },
                                { "value": "top-right", "icon": "dots_grid_top_right" },
                                { "value": "center-left", "icon": "dots_grid_center_left" },
                                { "value": "center", "icon": "dots_grid_center" },
                                { "value": "center-right", "icon": "dots_grid_center_right" },
                                { "value": "bottom-left", "icon": "dots_grid_bottom_left" },
                                { "value": "bottom-center", "icon": "dots_grid_bottom_center" },
                                { "value": "bottom-right", "icon": "dots_grid_bottom_right" }
                            ],
                            "condition": { "dependsOn": "thumbnail_custom_size_crop", "values": [true, "1", 1] },
                            "free": true
                        }
                    ]
                }
            ]
        },
        {
            "key": "full_image_size_group",
            "type": "setting_group",
            "label": "Full Image Size",
            "free": true,
            "settings": [
                {
                    "key": "full_image_size",
                    "type": "image_size",
                    "label": "",
                    "api_endpoint": "/wp-json/fotogrids/v1/admin/image-sizes",
                    "options_key": "sizes",
                    "default": "full",
                    "exclude_values": ["thumbnail"],
                    "append_option": { "label": "Custom", "value": "custom" },
                    "fallback_options": [
                        { "label": "Medium", "value": "medium" },
                        { "label": "Large", "value": "large" },
                        { "label": "Full", "value": "full" }
                    ],
                    "free": true
                },
                {
                    "key": "full_image_custom_size",
                    "type": "setting_group",
                    "label": "Custom Full Image Size",
                    "condition": { "dependsOn": "full_image_size", "values": ["custom"] },
                    "free": true,
                    "settings": [
                        {
                            "key": "full_image_custom_size_width",
                            "type": "range",
                            "label": "Width",
                            "min": 200,
                            "max": 2000,
                            "default": 800,
                            "unit": "px",
                            "free": true
                        },
                        {
                            "key": "full_image_custom_size_height",
                            "type": "range",
                            "label": "Height",
                            "min": 200,
                            "max": 2000,
                            "default": 800,
                            "unit": "px",
                            "free": true
                        },
                        {
                            "key": "full_image_custom_size_crop",
                            "type": "toggle",
                            "label": "Hard Crop",
                            "default": false,
                            "description": "When enabled, images will be cropped to the exact width and height specified.<br>When disabled, images will be scaled to fit the dimensions while maintaining their aspect ratio.",
                            "free": true
                        },
                        {
                            "key": "full_image_custom_size_crop_alignment",
                            "type": "alignment_grid",
                            "label": "Crop Alignment",
                            "default": "center",
                            "options": [
                                { "value": "top-left", "icon": "dots_grid_top_left" },
                                { "value": "top-center", "icon": "dots_grid_top_center" },
                                { "value": "top-right", "icon": "dots_grid_top_right" },
                                { "value": "center-left", "icon": "dots_grid_center_left" },
                                { "value": "center", "icon": "dots_grid_center" },
                                { "value": "center-right", "icon": "dots_grid_center_right" },
                                { "value": "bottom-left", "icon": "dots_grid_bottom_left" },
                                { "value": "bottom-center", "icon": "dots_grid_bottom_center" },
                                { "value": "bottom-right", "icon": "dots_grid_bottom_right" }
                            ],
                            "condition": { "dependsOn": "full_image_custom_size_crop", "values": [true, "1", 1] },
                            "free": true
                        }
                    ]
                }
            ]
        }
    ]
}
