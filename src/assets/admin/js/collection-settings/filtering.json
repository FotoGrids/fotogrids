{
    "id": "filtering",
    "label": "Filtering",
    "icon": "filter",
    "free": true,
    "settings": [
        {
            "key": "filtering_enabled",
            "type": "toggle",
            "label": "Enable Filtering",
            "description": "Allow items to be filtered by different criteria",
            "default": false,
            "free": true
        },
        {
            "key": "filter_by_tags",
            "type": "toggle",
            "label": "Filter by Tags",
            "description": "Allow filtering items by their assigned tags",
            "default": true,
            "condition": { "dependsOn": "filtering_enabled", "values": [true, "1"] },
            "free": true
        },
        {
            "key": "filter_by_date",
            "type": "toggle",
            "label": "Filter by Date",
            "description": "Allow filtering items by date range (date taken or uploaded)",
            "default": false,
            "condition": { "dependsOn": "filtering_enabled", "values": [true, "1"] },
            "free": false
        },
        {
            "key": "date_filter_type",
            "type": "button_group",
            "label": "Date Filter Type",
            "description": "Which date to use for filtering",
            "options": [
                { "label": "Date Taken", "value": "date_taken", "icon": "camera", "free": false },
                { "label": "Date Uploaded", "value": "date_uploaded", "icon": "upload", "free": false }
            ],
            "default": "date_taken",
            "condition": { "dependsOn": ["filtering_enabled", "filter_by_date"], "values": [[true, "1"], [true, "1"]] },
            "free": false
        },
        {
            "key": "filter_ui_group",
            "type": "setting_group",
            "label": "Filter Controls",
            "condition": { "dependsOn": "filtering_enabled", "values": [true, "1"] },
            "free": true,
            "settings": [
                {
                    "key": "filter_ui_position",
                    "type": "button_group",
                    "label": "Position",
                    "description": "Where to display the filter controls",
                    "options": [
                        { "label": "Top", "value": "top", "icon": "flex_align_top", "free": true },
                        { "label": "Sidebar", "value": "sidebar", "icon": "flex_align_left", "free": true }
                    ],
                    "default": "top",
                    "free": true
                },
                {
                    "key": "filter_ui_style",
                    "type": "button_group",
                    "label": "Style",
                    "description": "How the filter controls are displayed",
                    "options": [
                        { "label": "Dropdowns", "value": "dropdowns", "icon": "arrow_square_down", "free": true },
                        { "label": "Buttons", "value": "buttons", "icon": "layout", "free": true },
                        { "label": "Checkboxes", "value": "checkboxes", "icon": "check_square", "free": true }
                    ],
                    "default": "buttons",
                    "free": true
                },
                {
                    "key": "show_filter_count",
                    "type": "toggle",
                    "label": "Show Item Count",
                    "description": "Display the number of items in each filter option",
                    "default": true,
                    "free": true
                },
                {
                    "key": "filter_all_label",
                    "type": "text_input",
                    "label": "\"All\" Filter Label",
                    "description": "Text for the option that shows all items (e.g., 'All Items', 'Show All')",
                    "default": "All",
                    "free": true
                }
            ]
        },
        {
            "key": "advanced_filtering_promo",
            "type": "promo",
            "messages": [
                {
                    "subtitle": "Advanced EXIF & Metadata Filtering",
                    "message": "Filter by camera settings (ISO, aperture, shutter speed), file properties (size, dimensions), and other EXIF data to find exactly what you're looking for."
                },
                {
                    "subtitle": "People & Location Filtering",
                    "message": "Filter {postType.lower.plural} by recognized people or locations. Perfect for event photography, family albums, and location-based collections."
                },
                {
                    "subtitle": "Smart Filter Presets & Dynamic Filtering",
                    "message": "Save your favorite filter combinations as presets for quick access, and enable real-time filtering that updates results as users type or select options."
                }
            ],
            "free": false
        }
    ]
}
