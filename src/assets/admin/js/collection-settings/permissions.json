{
    "id": "permissions",
    "label": "Permissions",
    "icon": "lock",
    "free": true,
    "settings": [
        {
            "key": "edit_permission_group",
            "type": "setting_group",
            "label": "Edit Permissions",
            "description": "Control who can edit gallery and album posts",
            "free": false,
            "settings": [
                {
                    "key": "who_can_edit",
                    "type": "button_group",
                    "label": "Who can edit this Gallery?",
                    "options": [
                        { "label": "All", "value": "all" },
                        { "label": "Specific roles", "value": "specific_roles" },
                        { "label": "Specific users", "value": "specific_users" }
                    ],
                    "default": "all",
                    "free": true
                },
                {
                    "key": "edit_role_permission_type",
                    "type": "button_group",
                    "label": "Permission type",
                    "options": [
                        { "label": "Include", "value": "include", "icon": "check" },
                        { "label": "Exclude", "value": "exclude", "icon": "close" }
                    ],
                    "default": "include",
                    "condition": { "dependsOn": "who_can_edit", "values": ["specific_roles", "specific_users"] },
                    "free": true
                },
                {
                    "key": "edit_allowed_roles",
                    "type": "multi_select",
                    "label": "Select roles",
                    "options": [
                        { "label": "Administrator", "value": "administrator" },
                        { "label": "Editor", "value": "editor" },
                        { "label": "Author", "value": "author" },
                        { "label": "Contributor", "value": "contributor" },
                        { "label": "Subscriber", "value": "subscriber" }
                    ],
                    "default": [],
                    "condition": { "dependsOn": "who_can_edit", "values": ["specific_roles"] },
                    "free": true
                },
                {
                    "key": "edit_allowed_users",
                    "type": "user_select",
                    "label": "Select users",
                    "default": [],
                    "condition": { "dependsOn": "who_can_edit", "values": ["specific_users"] },
                    "free": true
                }
            ]
        },
        {
            "key": "view_permission_group",
            "type": "setting_group",
            "label": "View Permissions",
            "description": "Control who can view gallery and album posts",
            "free": true,
            "settings": [
                {
                    "key": "who_can_view",
                    "type": "button_group",
                    "label": "Who can view this Gallery?",
                    "options": [
                        { "label": "All", "value": "all", "free": true },
                        { "label": "Only registered users", "value": "registered_users", "free": true },
                        { "label": "Specific roles", "value": "specific_roles", "free": false }
                    ],
                    "default": "all",
                    "free": true
                },
                {
                    "key": "view_role_permission_type",
                    "type": "button_group",
                    "label": "Permission type",
                    "options": [
                        { "label": "Include", "value": "include", "icon": "check" },
                        { "label": "Exclude", "value": "exclude", "icon": "close" }
                    ],
                    "default": "include",
                    "condition": { "dependsOn": "who_can_view", "values": ["specific_roles"] },
                    "free": true
                },
                {
                    "key": "view_allowed_roles",
                    "type": "multi_select",
                    "label": "Select roles",
                    "options": [
                        { "label": "Administrator", "value": "administrator" },
                        { "label": "Editor", "value": "editor" },
                        { "label": "Author", "value": "author" },
                        { "label": "Contributor", "value": "contributor" },
                        { "label": "Subscriber", "value": "subscriber" }
                    ],
                    "default": [],
                    "condition": { "dependsOn": "who_can_view", "values": ["specific_roles"] },
                    "free": true
                }
            ]
        }
    ]
}
