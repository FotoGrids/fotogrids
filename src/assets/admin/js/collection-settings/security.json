{
    "id": "security",
    "label": "Security",
    "icon": "security",
    "free": true,
    "settings": [
        {
            "key": "disable_right_click",
            "type": "toggle",
            "label": "Disable Right Click",
            "free": false
        },
        {
            "key": "password_protect_group",
            "type": "setting_group",
            "label": "Password Protection",
            "free": true,
            "settings": [
                {
                    "key": "password_protect",
                    "type": "toggle",
                    "label": "Password Protect Gallery",
                    "free": true
                },
                {
                    "key": "password",
                    "type": "password_input",
                    "label": "Gallery Password",
                    "default": "",
                    "free": true,
                    "condition": { "dependsOn": "password_protect", "values": [true, "1"] }
                }
            ]
        },
        {
            "key": "watermark_generation_group",
            "type": "setting_group",
            "label": "Watermark Generation",
            "free": true,
            "settings": [
                {
                    "key": "enable_watermark",
                    "type": "toggle",
                    "label": "Enable Watermark",
                    "default": false,
                    "free": true
                },
                {
                    "key": "watermark_type",
                    "type": "button_group",
                    "label": "Watermark Type",
                    "options": [
                        { "label": "Text", "value": "text", "free": true },
                        { "label": "Image", "value": "image", "free": false }
                    ],
                    "default": "text",
                    "condition": { "dependsOn": "enable_watermark", "values": [true, "1"] },
                    "free": true
                },
                {
                    "key": "watermark_image_settings_group",
                    "type": "setting_group",
                    "label": "Image Settings",
                    "free": false,
                    "condition": { "dependsOn": ["enable_watermark", "watermark_type"], "values": [[true, "1"], ["image"]] },
                    "settings": [
                        {
                            "key": "watermark_image_url",
                            "type": "text_input",
                            "label": "Watermark Image URL",
                            "default": "",
                            "placeholder": "Enter image URL or upload",
                            "free": false
                        },
                        {
                            "key": "watermark_image_size",
                            "type": "range",
                            "label": "Image Size",
                            "unit": "%",
                            "min": 5,
                            "max": 50,
                            "default": 20,
                            "free": false
                        }
                    ]
                },
                {
                    "key": "watermark_settings_subtabs",
                    "type": "setting_subtabs",
                    "label": "Watermark Settings",
                    "free": true,
                    "condition": { "dependsOn": "enable_watermark", "values": [true, "1"] },
                    "subTabs": {
                        "text_settings": {
                            "id": "text_settings",
                            "label": "Text Settings",
                            "icon": "text",
                            "condition": { "dependsOn": "watermark_type", "values": ["text"] },
                            "settings": [
                                {
                                    "key": "watermark_text",
                                    "type": "text_input",
                                    "label": "Watermark Text",
                                    "default": "© Your Name",
                                    "placeholder": "Enter watermark text",
                                    "free": true
                                },
                                {
                                    "key": "watermark_font_size",
                                    "type": "range",
                                    "label": "Font Size",
                                    "unit": "px",
                                    "min": 12,
                                    "max": 48,
                                    "default": 24,
                                    "free": true
                                },
                                {
                                    "key": "watermark_text_color",
                                    "type": "button_group",
                                    "label": "Text Color",
                                    "options": [
                                        { "label": "Light", "value": "light" },
                                        { "label": "Dark", "value": "dark" },
                                        { "label": "Custom", "value": "custom", "free": false }
                                    ],
                                    "default": "light",
                                    "free": true
                                },
                                {
                                    "key": "watermark_custom_text_color",
                                    "type": "color_picker",
                                    "label": "Custom Text Color",
                                    "condition": { "dependsOn": "watermark_text_color", "values": ["custom"] },
                                    "default": "#ffffff",
                                    "free": false
                                },
                                {
                                    "key": "watermark_font_family",
                                    "type": "button_group",
                                    "label": "Font Family",
                                    "options": [
                                        { "label": "Arial", "value": "Arial" },
                                        { "label": "Helvetica", "value": "Helvetica" },
                                        { "label": "Times New Roman", "value": "Times New Roman" },
                                        { "label": "Georgia", "value": "Georgia" },
                                        { "label": "Courier New", "value": "Courier New" },
                                        { "label": "Custom", "value": "custom", "free": false }
                                    ],
                                    "default": "Arial",
                                    "free": true
                                },
                                {
                                    "key": "watermark_custom_font",
                                    "type": "text_input",
                                    "label": "Custom Font Family",
                                    "placeholder": "e.g., 'Roboto', 'Open Sans'",
                                    "condition": { "dependsOn": "watermark_font_family", "values": ["custom"] },
                                    "free": false
                                }
                            ]
                        },
                        "position_styling": {
                            "id": "position_styling",
                            "label": "Position & Styling",
                            "icon": "styling",
                            "settings": [
                                {
                                    "key": "watermark_position",
                                    "type": "alignment_grid",
                                    "label": "Position",
                                    "options": [
                                        { "value": "top-left", "icon": "dots_grid_top_left", "free": true },
                                        { "value": "top-center", "icon": "dots_grid_top_center", "free": true },
                                        { "value": "top-right", "icon": "dots_grid_top_right", "free": true },
                                        { "value": "center-left", "icon": "dots_grid_center_left", "free": true },
                                        { "value": "center", "icon": "dots_grid_center", "free": true },
                                        { "value": "center-right", "icon": "dots_grid_center_right", "free": true },
                                        { "value": "bottom-left", "icon": "dots_grid_bottom_left", "free": true },
                                        { "value": "bottom-center", "icon": "dots_grid_bottom_center", "free": true },
                                        { "value": "bottom-right", "icon": "dots_grid_bottom_right", "free": true }
                                    ],
                                    "default": "bottom-right",
                                    "free": true
                                },
                                {
                                    "key": "watermark_opacity",
                                    "type": "range",
                                    "label": "Opacity",
                                    "unit": "%",
                                    "min": 10,
                                    "max": 100,
                                    "default": 70,
                                    "free": true
                                },
                                {
                                    "key": "watermark_margin",
                                    "type": "responsive_range",
                                    "label": "Margin",
                                    "responsive": {
                                        "desktop": { "min": 0, "max": 100, "default": 20 },
                                        "tablet": { "min": 0, "max": 80, "default": 15 },
                                        "mobile": { "min": 0, "max": 60, "default": 10 }
                                    },
                                    "unit": "px",
                                    "free": false
                                }
                            ]
                        },
                        "advanced": {
                            "id": "advanced",
                            "label": "Advanced",
                            "icon": "settings",
                            "settings": [
                                {
                                    "key": "watermark_apply_to",
                                    "type": "button_group",
                                    "label": "Apply Watermark To",
                                    "options": [
                                        { "label": "Full Images Only", "value": "full", "free": true },
                                        { "label": "Thumbnails Only", "value": "thumbnails", "free": false },
                                        { "label": "Both", "value": "both", "free": false }
                                    ],
                                    "default": "full",
                                    "free": true
                                },
                                {
                                    "key": "watermark_repeat",
                                    "type": "toggle",
                                    "label": "Repeat Watermark",
                                    "default": false,
                                    "free": false
                                },
                                {
                                    "key": "watermark_repeat_spacing",
                                    "type": "responsive_range",
                                    "label": "Repeat Spacing",
                                    "responsive": {
                                        "desktop": { "min": 50, "max": 500, "default": 200 },
                                        "tablet": { "min": 40, "max": 400, "default": 150 },
                                        "mobile": { "min": 30, "max": 300, "default": 100 }
                                    },
                                    "unit": "px",
                                    "condition": { "dependsOn": "watermark_repeat", "values": [true, "1"] },
                                    "free": false
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ]
}
