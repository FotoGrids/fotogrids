{
    "id": "interactions",
    "label": "Interactions",
    "icon": "click",
    "free": true,
    "settings": [
        {
            "key": "item_click_behavior",
            "type": "button_group",
            "label": "Item Click Behavior",
            "options": [
                {
                    "label": "Do Nothing",
                    "value": "nothing",
                    "icon": "click_nothing"
                },
                {
                    "label": "Open in Lightbox",
                    "value": "lightbox",
                    "icon": "click_lightbox"
                },
                {
                    "label": "Direct Link to Item",
                    "value": "direct",
                    "icon": "click_direct"
                },
                {
                    "label": "External URL",
                    "value": "external",
                    "icon": "click_external"
                }
            ],
            "free": true
        },
        {
            "key": "external_link_target",
            "type": "button_group",
            "label": "Default Link Target",
            "options": [
                { "label": "Same Tab", "value": "_self", "icon": "check_square" },
                { "label": "New Tab", "value": "_blank", "icon": "plus_square" }
            ],
            "condition": { "dependsOn": "item_click_behavior", "values": ["external"] },
            "free": true
        },
        {
            "key": "external_url_manager",
            "type": "external_url_manager",
            "label": "Item URLs",
            "condition": { "dependsOn": "item_click_behavior", "values": ["external"] },
            "free": true
        },
        {
            "key": "lightbox_settings_section",
            "type": "lightbox_subtabs",
            "condition": { "dependsOn": "item_click_behavior", "values": ["lightbox"] },
            "free": true,
            "subTabs": {
                "layout_styling": {
                    "id": "layout_styling",
                    "label": "Lightbox Layout & Styling",
                    "icon": "layout",
                    "settings": [
                        {
                            "key": "lightbox_theme",
                            "type": "button_group",
                            "label": "Lightbox Theme",
                            "options": [
                                { "label": "Dark", "value": "dark", "icon": "theme_dark" },
                                { "label": "Light", "value": "light", "icon": "theme_light" },
                                { "label": "Custom", "value": "custom", "icon": "theme_custom" }
                            ],
                            "free": true
                        },
                        {
                            "key": "lightbox_custom_color",
                            "type": "color",
                            "label": "Custom Theme Color",
                            "condition": { "dependsOn": "lightbox_theme", "values": ["custom"] },
                            "free": true
                        },
                        {
                            "key": "lightbox_fit_media",
                            "type": "toggle",
                            "label": "Fit Media to Screen",
                            "free": true
                        },
                        {
                            "key": "lightbox_mobile_layout",
                            "type": "button_group",
                            "label": "Mobile Layout",
                            "options": [
                                { "label": "Mobile Optimized", "value": "mobile_optimized", "icon": "responsive_mobile" },
                                { "label": "Same as Desktop", "value": "same_as_desktop", "icon": "responsive_desktop" }
                            ],
                            "free": true
                        }
                    ]
                },
                "navigation": {
                    "id": "navigation",
                    "label": "Lightbox Navigation",
                    "icon": "transition_horizontal",
                    "settings": [
                        {
                            "key": "lightbox_transition_group",
                            "type": "setting_group",
                            "label": "Transition",
                            "free": true,
                            "settings": [
                                {
                                    "key": "lightbox_transition",
                                    "type": "button_group",
                                    "label": "Transition Between Items",
                                    "options": [
                                        { "label": "Fade", "value": "fade", "icon": "transition_fade" },
                                        { "label": "Horizontal", "value": "horizontal", "icon": "transition_horizontal" },
                                        { "label": "Vertical", "value": "vertical", "icon": "transition_vertical" },
                                        { "label": "None", "value": "none", "icon": "x" }
                                    ],
                                    "free": true
                                },
                                {
                                    "key": "lightbox_transition_duration",
                                    "type": "button_group",
                                    "label": "Transition Duration",
                                    "options": [
                                        { "label": "Fast", "unit": "ms", "value": 150 },
                                        { "label": "Normal", "unit": "ms", "value": 300 },
                                        { "label": "Slow", "unit": "ms", "value": 450 },
                                        { "label": "Custom", "value": "custom" }
                                    ],
                                    "condition": { "dependsOn": "lightbox_transition", "values": ["fade", "horizontal", "vertical"] },
                                    "free": true
                                },
                                {
                                    "key": "lightbox_transition_duration_custom",
                                    "type": "range",
                                    "label": "Custom Duration",
                                    "unit": "ms",
                                    "min": 0,
                                    "max": 1000,
                                    "condition": { "dependsOn": "lightbox_transition_duration", "values": ["custom"] },
                                    "free": true
                                }
                            ]
                        },
                        {
                            "key": "lightbox_auto_progress_group",
                            "type": "setting_group",
                            "label": "Auto Progress",
                            "free": true,
                            "settings": [
                                {
                                    "key": "lightbox_auto_progress",
                                    "type": "toggle",
                                    "label": "Enable Auto Progress",
                                    "free": true
                                },
                                {
                                    "key": "lightbox_auto_progress_delay",
                                    "type": "range",
                                    "label": "Delay",
                                    "unit": "seconds",
                                    "min": 1,
                                    "max": 20,
                                    "condition": { "dependsOn": "lightbox_auto_progress", "values": [true, "1"] },
                                    "free": true
                                }
                            ]
                        },
                        {
                            "key": "lightbox_navigation_arrows_group",
                            "type": "setting_group",
                            "label": "Navigation Arrows",
                            "free": true,
                            "settings": [
                                {
                                    "key": "lightbox_show_arrows",
                                    "type": "toggle",
                                    "label": "Show Navigation Arrows",
                                    "free": true
                                },
                                {
                                    "key": "lightbox_arrow_icon",
                                    "type": "button_group",
                                    "label": "Arrow Icon Style",
                                    "options": [
                                        { "value": "chevron", "icon": "chevron" },
                                        { "value": "arrow", "icon": "arrow" },
                                        { "value": "triangle", "icon": "triangle" }
                                    ],
                                    "condition": { "dependsOn": "lightbox_show_arrows", "values": [true, "1"] },
                                    "free": true
                                },
                                {
                                    "key": "lightbox_arrow_size",
                                    "type": "range",
                                    "label": "Arrow Size",
                                    "min": 0,
                                    "max": 120,
                                    "default": 40,
                                    "units": ["px", "em", "rem", "%"],
                                    "condition": { "dependsOn": "lightbox_show_arrows", "values": [true, "1"] },
                                    "free": true
                                },
                                {
                                    "key": "lightbox_arrow_color",
                                    "type": "color",
                                    "label": "Arrow Color",
                                    "condition": { "dependsOn": "lightbox_show_arrows", "values": [true, "1"] },
                                    "free": true
                                }
                            ]
                        },
                        {
                            "key": "lightbox_navigation_dots_group",
                            "type": "setting_group",
                            "label": "Navigation Dots",
                            "free": true,
                            "settings": [
                                {
                                    "key": "lightbox_show_dots",
                                    "type": "toggle",
                                    "label": "Show Navigation Dots",
                                    "free": true
                                },
                                {
                                    "key": "lightbox_dot_style",
                                    "type": "button_group",
                                    "label": "Dot Style",
                                    "options": [
                                        { "label": "", "value": "fill", "icon": "dot_fill" },
                                        { "label": "", "value": "stroke", "icon": "dot_stroke" },
                                        { "label": "", "value": "square", "icon": "dot_square" },
                                        { "label": "", "value": "square_stroke", "icon": "dot_square_stroke" }
                                    ],
                                    "condition": { "dependsOn": "lightbox_show_dots", "values": [true, "1"] },
                                    "free": true
                                },
                                {
                                    "key": "lightbox_dot_color",
                                    "type": "color",
                                    "label": "Dot Color",
                                    "condition": { "dependsOn": "lightbox_show_dots", "values": [true, "1"] },
                                    "free": true
                                },
                                {
                                    "key": "lightbox_active_dot_color",
                                    "type": "color",
                                    "label": "Active Dot Color",
                                    "condition": { "dependsOn": "lightbox_show_dots", "values": [true, "1"] },
                                    "free": true
                                },
                                {
                                    "key": "lightbox_dots_spacing",
                                    "type": "range",
                                    "label": "Space Between Dots",
                                    "min": 0,
                                    "max": 30,
                                    "default": 8,
                                    "units": ["px", "em", "rem", "%"],
                                    "condition": { "dependsOn": "lightbox_show_dots", "values": [true, "1"] },
                                    "free": true
                                }
                            ]
                        }
                    ]
                },
                "thumbnails": {
                    "id": "thumbnails",
                    "label": "Lightbox Thumbnail Strip",
                    "icon": "flex-align-bottom",
                    "settings": [
                        {
                            "key": "lightbox_thumbnail_strip_location",
                            "type": "button_group",
                            "label": "Thumbnail Strip Location",
                            "options": [
                                { "label": "Bottom", "value": "bottom", "icon": "flex-align-bottom" },
                                { "label": "Top", "value": "top", "icon": "flex-align-top" },
                                { "label": "Left", "value": "left", "icon": "flex-align-left" },
                                { "label": "Right", "value": "right", "icon": "flex-align-right" },
                                { "label": "None", "value": "none", "icon": "x" }
                            ],
                            "free": true
                        },
                        {
                            "key": "lightbox_thumbnail_size",
                            "type": "button_group",
                            "label": "Thumbnail Size",
                            "options": [
                                { "label": "Small", "value": "small" },
                                { "label": "Normal", "value": "normal" },
                                { "label": "Large", "value": "large" }
                            ],
                            "condition": { "dependsOn": "lightbox_thumbnail_strip_location", "values": ["bottom", "top", "left", "right"] },
                            "free": true
                        }
                    ]
                }
            }
        }
    ]
}
