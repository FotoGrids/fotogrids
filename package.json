{
  "name": "fotogrids",
  "version": "0.1.0",
  "description": "FotoGrids WordPress gallery plugin with freemium Pro features",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development webpack --watch",
    "build": "cross-env NODE_ENV=production webpack",
    "build:dev": "cross-env NODE_ENV=development webpack",
    "clean": "rimraf dist",
    "lint": "eslint src/assets --ext .js,.ts,.tsx",
    "lint:fix": "eslint src/assets --ext .js,.ts,.tsx --fix",
    "format": "prettier --write 'src/assets/**/*.{js,ts,tsx,scss,css}' '**/*.md'",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "zip:dev": "npm run build:dev && cd dist/dev && zip -r ../../fotogrids-dev.zip . -x '*.map'",
    "zip:prod": "npm run build && cd dist/prod && zip -r ../../fotogrids-v$npm_package_version.zip . -x '*.map'",
    "release": "npm run clean && npm run build && npm run zip:prod"
  },
  "keywords": [
    "wordpress",
    "plugin",
    "gallery",
    "photos",
    "items"
  ],
  "author": "Your Name",
  "license": "GPL-2.0-or-later",
  "dependencies": {
    "@wordpress/api-fetch": "^6.0.0",
    "@wordpress/block-editor": "^12.0.0",
    "@wordpress/blocks": "^12.0.0",
    "@wordpress/components": "^25.0.0",
    "@wordpress/data": "^9.0.0",
    "@wordpress/element": "^5.0.0",
    "@wordpress/i18n": "^4.0.0",
    "chart.js": "^4.5.0",
    "react": "^17.0.0",
    "react-dom": "^17.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.22.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "babel-loader": "^9.1.0",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.0",
    "mini-css-extract-plugin": "^2.7.0",
    "sass": "^1.93.2",
    "sass-embedded": "^1.93.2",
    "sass-loader": "^14.2.1",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.4.0",
    "typescript": "^5.1.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
