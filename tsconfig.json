{
  "compilerOptions": {
    "target": "es2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
  "baseUrl": ".",
  "paths": {
    "@/*": ["src/assets/*"]
  },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/assets/admin/src/index-simple.tsx",
    "src/assets/admin/src/blocks/gallery-block-simple.tsx",
    "src/assets/admin/src/components/blocks/*-simple.tsx",
    "src/assets/admin/src/types/wordpress.d.ts",
    "src/assets/frontend/src/**/*",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "vendor"
  ]
}
